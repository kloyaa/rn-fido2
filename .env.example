# ============================================================
# rn-fido2 Environment Variables (Root Template)
# Copy to .env.local and fill in your values
# ============================================================

# --- Backend (api/) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=fido2_auth
DB_LOGGING=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=your-super-secret-jwt-key-min-32-chars-required
JWT_EXPIRATION=900
REFRESH_TOKEN_EXPIRATION=604800

NODE_ENV=development
APP_PORT=3000
APP_NAME=fido2-auth-api

RP_ID=localhost
RP_NAME=FIDO2 Auth Service
ORIGIN=http://localhost:3000

RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_ATTEMPTS=10
ACCOUNT_LOCK_DURATION_MS=900000
ACCOUNT_LOCK_THRESHOLD=5

LOG_LEVEL=debug

# --- Frontend (mobile/) ---
API_BASE_URL=http://localhost:3000
API_TIMEOUT_MS=30000
APP_VERSION=1.0.0-beta
